(* sml-async: public library basis.

   Exposes the Standard ML Basis plus the library sources. Consumers using
   smlpkg reference this file at
     lib/github.com/sjqtentacles/sml-async/sml-async.mlb
   from their own .mlb files (MLton / MLKit). For Poly/ML, feed sources.mlb
   to the tools/polybuild wrapper. *)

$(SML_LIB)/basis/basis.mlb

sources.mlb
